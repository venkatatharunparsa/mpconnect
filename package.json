{
  "name": "mpconnect-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @mpconnect/api dev",
    "dev:web": "pnpm --filter @mpconnect/web dev",
    "dev": "pnpm --parallel dev",
    "build:api": "pnpm --filter @mpconnect/api build",
    "build:web": "pnpm --filter @mpconnect/web build",
    "build": "pnpm --parallel build",
    "db:push": "pnpm --filter @mpconnect/api db:push",
    "db:studio": "pnpm --filter @mpconnect/api db:studio",
    "db:reset": "pnpm --filter @mpconnect/api db:reset",
    "seed": "pnpm --filter @mpconnect/api seed",
    "seed:demo": "pnpm --filter @mpconnect/api seed:demo",
    "seed:production": "pnpm --filter @mpconnect/api seed:production",
    "corpus:seed": "pnpm --filter @mpconnect/api exec tsx seed/corpus.ts",
    "demo:reset": "pnpm --filter @mpconnect/api demo:reset",
    "telegram:webhook": "pnpm --filter @mpconnect/api telegram:webhook",
    "test": "pnpm --filter @mpconnect/api test"
  },
  "devDependencies": {
    "typescript": "^5.6.2"
  }
}
