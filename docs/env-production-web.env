# Frontend Web Production Environment Variables (Copy & Paste to Vercel Settings)

# Replace with your actual production backend URL after deployment
NEXT_PUBLIC_API_URL=https://mpconnect-api.vercel.app

# Replace with your actual production frontend URL after deployment
NEXT_PUBLIC_SITE_URL=https://mpconnect-web.vercel.app

# Replace with your production-restricted Google Maps API JavaScript key
NEXT_PUBLIC_GOOGLE_MAPS_KEY=YOUR_GOOGLE_MAPS_KEY_HERE

# Replace with your browser Live API key if utilizing the Live voice agent
NEXT_PUBLIC_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
