# Backend API Production Environment Variables (Copy & Paste to Vercel Settings)

# Replace with your production database connection string
DATABASE_URL=postgresql://neondb_owner:<YOUR_NEON_PASSWORD>@ep-damp-paper-ahl5o47z.c-3.us-east-1.aws.neon.tech/neondb?sslmode=require

# Replace with your Google AI Studio key
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Replace with your Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Replace with your actual production backend URL after deployment
PUBLIC_URL=https://mpconnect-api.vercel.app

# Replace with your actual production frontend URL after deployment
CORS_ORIGINS=https://mpconnect-web.vercel.app

ENABLE_DEV_ENDPOINTS=false
