# Copy to .env.local and fill. NEVER commit real values.

# Neon/Supabase Postgres connection string
DATABASE_URL=postgresql://user:pass@host/dbname

# Google AI Studio key (Gemini multimodal + embeddings + Live)
GEMINI_API_KEY=

# Google Maps JavaScript API key (restrict to your domains)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# Public URL for the Telegram webhook (your deployment URL)
PUBLIC_URL=http://localhost:3000

# --- Socketed adapters (production path — not used in hackathon demo) ---
# WHATSAPP_BSP_TOKEN=
# EXOTEL_SID=            # toll-free voice line adapter
# BHASHINI_API_KEY=      # production Telugu ASR path
