# Frontend env — copy to apps/web/.env.local

# Backend API — required on Vercel (apps/web): https://mpconnect-api.vercel.app
NEXT_PUBLIC_API_URL=http://localhost:3000

# Google Maps (constituency map at /map + dashboard)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Gemini Live browser voice agent (optional)
NEXT_PUBLIC_GEMINI_API_KEY=

# Public site URL (SSR metadata for /p/[id])
NEXT_PUBLIC_SITE_URL=http://localhost:3001
